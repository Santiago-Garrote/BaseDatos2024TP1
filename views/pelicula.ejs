<!DOCTYPE html>
<html>
<head>
<title><%= movie.title %></title>
<link rel="stylesheet" href="/styles.css">
</head>
<body>
<h1><%= movie.title %></h1>
<h3>Fecha: <%= movie.release_date %></h3>
<h3>Directores</h3>
<ul>
    <% movie.directors.forEach((director) => { %>
        <li>
            <a href="/director/<%= director.crew_member_id %>"><%= director.crew_member_name %></a>
        </li>
    <% }); %>
</ul>
<h3>Budget && Language: </h3>
<div id="budget"><p><%= movie.budget %></p></div>
<div id="language"><p><%= movie.language %></p></div>
<h1> Popularidad && run_time.id = console.log(id): </h1>
<div id="popularity"><p><%= movie.popularity %></p></div>
<div id="runtime"><p><%= movie.runtime %></p></div>
<h1> ME canse de esto: </h1>
<div id="homepage"><p><%= movie.homepage %></p></div>
<div id="reveneu"><p><%= movie.reveneu %></p></div>
<div id="movie_status"><p><%= movie.movie_status %></p></div>
<div id="tagline"><p><%= movie.tagline %></p></div>
<div id="vote_average"><p><%= movie.vote_average %></p></div>
<div id="vote_count"><p><%= movie.vote_count %></p></div>
<div id="genre"><p><%= movie.genre %></p></div>
<div id="production_company"><p><%= movie.production_company %></p></div>
<div id="producx"><p><%= movie.production_country %></p></div>


<h3>Argumento:</h3>
<div id="overview"><p><%= movie.overview %></p></div>
<h2>Elenco</h2>
<ul>
    <% movie.cast.forEach((actor) => { %>
        <li>
            <a href="/actor/<%= actor.actor_id %>"><%= actor.actor_name %></a> (como <%= actor.character_name %>)
        </li>
    <% }); %>
</ul>
<h3>Crew:</h3>
<ul>
    <% movie.crew.forEach((crew_member) => { %>
        <li>
            <%= crew_member.crew_member_name %> - <%= crew_member.job %>
        </li>
    <% }); %>
</ul>
<div id="inicio"><a href="/">Inicio</a></div>
</body>
</html>

