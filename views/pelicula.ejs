<!DOCTYPE html>
<html>
<head>
<title><%= movies.title %></title>
<link rel="stylesheet" href="/styles.css">
</head>
<body>
<h1><%= movies.title %></h1>
<h3>Fecha: <%= movies.release_date %></h3>
<h3>Directores</h3>
<ul>
    <% movies.directors.forEach((director) => { %>
        <li>
            <a href="/director/"><%= director%></a>
        </li>
    <% }); %>
</ul>
<h3>Budget && Language: </h3>
<div id="budget"><p><%= movies.budget %></p></div>
<div id="language"><p><%= movies.language %></p></div>
<h1> Popularidad && run_time.id = console.log(id): </h1>
<div id="popularity"><p><%= movies.popularity %></p></div>
<div id="runtime"><p><%= movies.runtime %></p></div>
<h1> ME canse de esto: </h1>
<div id="homepage"><p><%= movies.homepage %></p></div>
<div id="reveneu"><p><%= movies.reveneu %></p></div>
<div id="movie_status"><p><%= movies.movie_status %></p></div>
<div id="tagline"><p><%= movies.tagline %></p></div>
<div id="vote_average"><p><%= movies.vote_average %></p></div>
<div id="vote_count"><p><%= movies.vote_count %></p></div>
<div id="genre"><p><%= movies.genre %></p></div>
<div id="production_company"><p><%= movies.production_company %></p></div>
<div id="producx"><p><%= movies.production_country %></p></div>


<h3>Argumento:</h3>
<div id="overview"><p><%= movies.overview %></p></div>
<h2>Elenco</h2>
<ul>
    <% movies.cast.forEach((actor) => { %>
        <li>
            <a href="/actor/<%= actor.actor_id %>"><%= actor.actor_name %></a> (como <%= actor.character_name %>)
        </li>
    <% }); %>
</ul>
<h3>Crew:</h3>
<ul>
    <a
</ul>
<div id="inicio"><a href="/">Inicio</a></div>
</body>
</html>

